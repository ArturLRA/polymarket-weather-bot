# Copie este arquivo para .env e preencha com seus valores reais

# OBRIGATÓRIO: chave privada da sua carteira Polygon
# NUNCA compartilhe ou commite este valor!
POLY_PRIVATE_KEY=sua-private-key-aqui

# OPCIONAL: apenas para proxy/email wallets (Magic, Sequence)
# Se usou MetaMask ou gerou via Python, deixe em branco
POLY_FUNDER_ADDRESS=
POLY_SIGNATURE_TYPE=0

# OPCIONAL: para validação extra com IA (Claude)
# Se não colocar, o bot usa só a matemática
ANTHROPIC_API_KEY=sk-ant-...
